---
const {
	href,
	title,
	body,
	icon,
	accent = false,
	span = 1,
	bullets,
} = Astro.props;

const Tag = href ? 'a' : 'div';
const items = Array.isArray(bullets) ? bullets : null;
---

<Tag
	class:list={["home-card", accent && "home-card--accent"]}
	href={href}
	data-span={span}
>
	<div class="home-card__head">
		{icon && (
			<span class="home-card__icon" aria-hidden="true">{icon}</span>
		)}
		<h3 class="home-card__title">{title}</h3>
	</div>
	{body && <p class="home-card__body">{body}</p>}
	{items && (
		<ul class="home-card__list">
			{items.map((it) => <li>{it}</li>)}
		</ul>
	)}
	<slot />
</Tag>
