---
const {
	href,
	title,
	body,
	icon,
	accent = false,
	span = 1,
	bullets,
} = Astro.props;

const Tag = href ? 'a' : 'div';
const items = Array.isArray(bullets) ? bullets : null;
---

<Tag
	class:list={["home-card", accent && "home-card--accent"]}
	href={href}
	data-span={span}
>
	<div class="home-card__head">
		{icon && (
			<span class="home-card__icon" aria-hidden="true">{icon}</span>
		)}
		<h3 class="home-card__title">{title}</h3>
	</div>
	{body && <p class="home-card__body">{body}</p>}
	{items && (
		<ul class="home-card__list">
			{items.map((it) => <li>{it}</li>)}
		</ul>
	)}
	<slot />
</Tag>

<style>
	.home-card {
		display: grid;
		grid-template-rows: auto auto 1fr;
		gap: 0.5rem;
		padding: 1rem 1.1rem 1.05rem;
		border-radius: 0.45rem;
		border: 1px solid color-mix(in srgb, var(--sl-color-white) 8%, transparent);
		background: color-mix(in srgb, var(--sl-color-white) 2%, transparent);
		text-decoration: none;
		color: inherit;
		transition: border-color 130ms ease, background 130ms ease;
	}

	.home-card[data-span='2'] {
		grid-column: span 2;
	}

	a.home-card:hover {
		border-color: color-mix(in srgb, var(--sl-color-accent) 55%, transparent);
		background: color-mix(in srgb, var(--sl-color-accent) 5%, transparent);
	}

	.home-card--accent {
		border-color: color-mix(in srgb, #22c55e 40%, transparent);
		background: color-mix(in srgb, #16a34a 12%, transparent);
	}

	a.home-card--accent:hover {
		border-color: color-mix(in srgb, #22c55e 65%, transparent);
		background: color-mix(in srgb, #16a34a 18%, transparent);
	}

	.home-card__head {
		display: flex;
		align-items: center;
		gap: 0.55rem;
	}

	.home-card__icon {
		display: inline-grid;
		place-items: center;
		width: 1.55rem;
		height: 1.55rem;
		border-radius: 0.35rem;
		background: color-mix(in srgb, var(--sl-color-accent) 16%, transparent);
		color: var(--sl-color-accent-high);
		font-size: 0.95rem;
		font-weight: 700;
		flex-shrink: 0;
	}

	.home-card--accent .home-card__icon {
		background: color-mix(in srgb, #22c55e 22%, transparent);
		color: #86efac;
	}

	.home-card__title {
		margin: 0;
		font-size: 0.98rem;
		font-weight: 600;
		color: var(--sl-color-white);
		letter-spacing: -0.005em;
	}

	.home-card__body {
		margin: 0;
		font-size: 0.86rem;
		color: var(--sl-color-gray-2);
		line-height: 1.5;
	}

	.home-card__list {
		margin: 0;
		padding: 0 0 0 1rem;
		font-size: 0.85rem;
		color: var(--sl-color-gray-2);
		line-height: 1.55;
		display: grid;
		gap: 0.1rem;
	}

	.home-card__list li {
		margin: 0;
	}

	@media (max-width: 900px) {
		.home-card[data-span='2'] {
			grid-column: span 1;
		}
	}

	:global(:root[data-theme='light']) .home-card {
		background: #ffffff;
		border-color: #e2e8f0;
	}

	:global(:root[data-theme='light']) a.home-card:hover {
		background: #f8fbff;
		border-color: var(--sl-color-accent);
	}

	:global(:root[data-theme='light']) .home-card__title {
		color: #0f172a;
	}

	:global(:root[data-theme='light']) .home-card__body,
	:global(:root[data-theme='light']) .home-card__list {
		color: #475569;
	}

	:global(:root[data-theme='light']) .home-card__icon {
		background: #eff6ff;
		color: #1d4ed8;
	}

	:global(:root[data-theme='light']) .home-card--accent {
		background: #ecfdf5;
		border-color: #bbf7d0;
	}

	:global(:root[data-theme='light']) .home-card--accent .home-card__icon {
		background: #d1fae5;
		color: #047857;
	}

	:global(:root[data-theme='light']) a.home-card--accent:hover {
		background: #d1fae5;
		border-color: #34d399;
	}
</style>
