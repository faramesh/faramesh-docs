---
const { items = [] } = Astro.props;
---

<div class="fm-grid">
	{items.map((it) => (
		<a class="fm-tile" href={it.href}>
			<div class="fm-tile__icon" aria-hidden="true">{it.icon}</div>
			<h3 class="fm-tile__title">{it.title}</h3>
			<p class="fm-tile__body">{it.body}</p>
			<span class="fm-tile__cta">{it.cta ?? 'Read more'} →</span>
		</a>
	))}
</div>

<style>
	.fm-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
		gap: 0.85rem;
		margin: 1.25rem 0 1.5rem;
	}

	.fm-tile {
		display: grid;
		grid-template-rows: auto auto 1fr auto;
		gap: 0.55rem;
		padding: 1rem 1.05rem 1.1rem;
		border-radius: 0.7rem;
		border: 1px solid color-mix(in srgb, var(--sl-color-white) 8%, transparent);
		background: color-mix(in srgb, var(--sl-color-white) 2%, transparent);
		text-decoration: none;
		color: inherit;
		transition: border-color 0.15s ease, background 0.15s ease, transform 0.05s ease;
	}

	.fm-tile:hover {
		border-color: color-mix(in srgb, var(--sl-color-accent) 60%, transparent);
		background: color-mix(in srgb, var(--sl-color-accent) 5%, transparent);
		transform: translateY(-1px);
	}

	.fm-tile__icon {
		font-size: 1.3rem;
		width: 2rem;
		height: 2rem;
		display: grid;
		place-items: center;
		border-radius: 0.45rem;
		background: color-mix(in srgb, var(--sl-color-accent) 16%, transparent);
		color: var(--sl-color-accent-high);
		font-weight: 700;
	}

	.fm-tile__title {
		font-size: 1rem;
		margin: 0;
		color: var(--sl-color-white);
		font-weight: 600;
		letter-spacing: -0.005em;
	}

	.fm-tile__body {
		margin: 0;
		font-size: 0.9rem;
		color: var(--sl-color-gray-2);
		line-height: 1.55;
	}

	.fm-tile__cta {
		font-size: 0.82rem;
		color: var(--sl-color-accent-high);
		font-weight: 600;
	}

	:root[data-theme='light'] .fm-tile {
		background: #ffffff;
		border-color: #e2e8f0;
	}
	:root[data-theme='light'] .fm-tile:hover {
		background: #f8fbff;
		border-color: var(--sl-color-accent);
	}
</style>
