---
import Search from '@astrojs/starlight/components/Search.astro';
import ThemeSelect from '@astrojs/starlight/components/ThemeSelect.astro';
import { getSectionForPath, headerSections } from '../lib/docs-nav.js';

import logoDark from '../assets/logo-docs-dark-.svg';
import logoLight from '../assets/docs-logo-light.svg';

const { siteTitleHref } = Astro.locals.starlightRoute;
const currentSection = getSectionForPath(Astro.url.pathname);
const currentPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const logoDarkSrc = typeof logoDark === 'string' ? logoDark : logoDark.src;
const logoLightSrc = typeof logoLight === 'string' ? logoLight : logoLight.src;

const linkHref = (item) => item.slug ? `/${item.slug.replace(/^\//, '')}/` : item.link;
const linkLabel = (item) => {
	if (item.label) return item.label;
	if (item.slug) {
		return item.slug
			.split('/')
			.pop()
			?.replace(/-/g, ' ')
			.replace(/\b\w/g, (ch) => ch.toUpperCase());
	}
	return item.link;
};

const isCurrent = (href) => {
	const normalized = href.endsWith('/') ? href : `${href}/`;
	return normalized === currentPath;
};
---

<header class="site-header" transition:persist="site-header" transition:name="site-header">
	<div class="site-header__inner">
		<a class="site-brand" href={siteTitleHref} aria-label="Faramesh Docs home">
			<img class="site-brand__logo site-brand__logo--light" src={logoLightSrc} alt="Faramesh Docs" />
			<img class="site-brand__logo site-brand__logo--dark" src={logoDarkSrc} alt="Faramesh Docs" />
		</a>
		<span class="brand-divider" aria-hidden="true"></span>

		<button class="mobile-menu-toggle" aria-expanded="false" aria-controls="site-tabs" aria-label="Toggle menu">
			<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
				<path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
		</button>

		<nav id="site-tabs" class="site-tabs" aria-label="Sections">
			{headerSections.map((section) => (
				<a
					href={section.href}
					class:list={{ 'site-tabs__item': true, 'site-tabs__item--active': currentSection.id === section.id }}
					aria-current={currentSection.id === section.id ? 'page' : undefined}
				>
					{section.label}
				</a>
			))}
		</nav>

		<div class="site-actions">
			<div class="site-search">
				<Search />
			</div>
			<a class="site-icon-link" href="https://github.com/faramesh/faramesh-docs" aria-label="GitHub">
				<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18" fill="currentColor">
					<path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.72.5.09.68-.22.68-.48v-1.74c-2.78.62-3.37-1.38-3.37-1.38-.46-1.2-1.12-1.52-1.12-1.52-.92-.65.07-.64.07-.64 1.02.08 1.56 1.07 1.56 1.07.9 1.58 2.35 1.12 2.92.86.09-.68.35-1.12.63-1.38-2.22-.26-4.55-1.14-4.55-5.08 0-1.12.38-2.03 1.01-2.75-.1-.26-.44-1.3.1-2.7 0 0 .83-.27 2.72 1.05a9.1 9.1 0 0 1 4.95 0c1.88-1.32 2.72-1.05 2.72-1.05.54 1.4.2 2.44.1 2.7.63.72 1.01 1.63 1.01 2.75 0 3.95-2.33 4.82-4.56 5.07.36.34.69 1 .69 2.02v2.99c0 .27.18.58.69.48A10.28 10.28 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z" />
				</svg>
			</a>
			<div class="site-theme">
				<ThemeSelect />
			</div>
		</div>

		<div class="site-mobile-pages" aria-label="Pages in this section">
			<div class="site-mobile-pages__title">Pages in this section</div>
			{currentSection.sidebar.map((group) => {
				const groupIsCurrent = group.items.some((item) => isCurrent(linkHref(item)));

				return (
					<details class="site-mobile-group" open={groupIsCurrent}>
						<summary class="site-mobile-group__summary">
							<span>{group.label}</span>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
								<path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</summary>
						<ul class="site-mobile-group__items">
							{group.items.map((item) => {
								const href = linkHref(item);
								const current = isCurrent(href);

								return (
									<li>
										<a
											href={href}
											class:list={{ 'site-mobile-group__link': true, 'site-mobile-group__link--current': current }}
											aria-current={current ? 'page' : undefined}
										>
											{linkLabel(item)}
										</a>
									</li>
								);
							})}
						</ul>
					</details>
				);
			})}
		</div>
	</div>
</header>

<style>
	.site-header {
		position: fixed;
		inset-block-start: 0;
		inset-inline-start: 0;
		width: 100%;
		z-index: 50;
		background: var(--sl-color-bg);
		border-bottom: 1px solid color-mix(in srgb, var(--sl-color-white) 8%, transparent);
	}

	.site-header__inner {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.45rem 0.9rem;
		max-width: 100%;
	}

	.site-brand {
		display: inline-flex;
		align-items: center;
		flex: none;
		text-decoration: none;
	}

	.site-brand__logo {
		width: auto;
		height: 1.6rem;
		object-fit: contain;
		flex: none;
	}

	.site-brand__logo--light {
		display: none;
	}

	.brand-divider {
		display: inline-block;
		width: 1px;
		height: 18px;
		background: color-mix(in srgb, var(--sl-color-white) 12%, transparent);
		margin-inline: 0.55rem 0.75rem;
		align-self: center;
	}

	.site-tabs {
		display: flex;
		align-items: center;
		gap: 0.15rem;
		min-width: 0;
		flex: 1;
		overflow-x: auto;
		white-space: nowrap;
		scrollbar-width: none;
	}

	.site-tabs::-webkit-scrollbar {
		display: none;
	}

	.site-tabs__item {
		display: inline-flex;
		align-items: center;
		height: 2.6rem;
		padding: 0 0.1rem;
		margin-right: 0.8rem;
		background: transparent;
		border-radius: 0;
		color: var(--sl-color-gray-2);
		text-decoration: none;
		font-size: 0.78rem;
		font-weight: 600;
		border-bottom: 2px solid transparent;
		white-space: nowrap;
	}

	.site-tabs__item:hover {
		background: transparent;
		color: var(--sl-color-white);
	}

	.site-tabs__item--active {
		background: transparent;
		color: var(--sl-color-white);
		border-bottom-color: var(--sl-color-accent);
	}

	.site-actions {
		display: inline-flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.55rem;
		flex: none;
	}

	.site-icon-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border-radius: 0.45rem;
		color: var(--sl-color-gray-2);
		text-decoration: none;
		transition: color 140ms ease, background-color 140ms ease;
	}

	.site-icon-link:hover {
		color: var(--sl-color-white);
		background: color-mix(in srgb, var(--sl-color-white) 6%, transparent);
	}

	.site-search :global(button[data-open-modal]) {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		padding: 0.5rem 0.75rem;
		border: 1px solid color-mix(in srgb, var(--sl-color-white) 12%, transparent);
		border-radius: 0.45rem;
		background: color-mix(in srgb, var(--sl-color-white) 4%, transparent);
		color: var(--sl-color-gray-2);
		box-shadow: none;
	}

	.site-search :global(button[data-open-modal]:hover) {
		color: var(--sl-color-white);
		border-color: color-mix(in srgb, var(--sl-color-white) 18%, transparent);
		background: color-mix(in srgb, var(--sl-color-white) 8%, transparent);
	}

	.site-search :global(button[data-open-modal] svg) {
		flex: none;
	}

	.site-search :global(button[data-open-modal] span),
	.site-search :global(button[data-open-modal] kbd) {
		color: inherit;
	}

	.site-theme :global(starlight-theme-select label) {
		--sl-select-width: 2.45rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.45rem;
		height: 2.15rem;
		padding: 0;
		border-radius: 0.45rem;
		background: transparent;
		border: 1px solid color-mix(in srgb, var(--sl-color-white) 10%, transparent);
		color: var(--sl-color-gray-2);
	}

	.site-theme {
		margin-left: 0;
	}

	.site-theme :global(starlight-theme-select label:hover) {
		color: var(--sl-color-white);
		border-color: color-mix(in srgb, var(--sl-color-white) 18%, transparent);
		background: color-mix(in srgb, var(--sl-color-white) 6%, transparent);
	}

	.site-theme :global(starlight-theme-select label select) {
		font-size: 0;
		color: transparent;
		text-indent: -9999px;
	}

	.site-theme :global(starlight-theme-select label option) {
		color: var(--sl-color-gray-1);
		background-color: var(--sl-color-bg-nav);
	}

	/* Mobile menu toggle button */
	.mobile-menu-toggle {
		display: none;
		align-items: center;
		justify-content: center;
		width: 2.4rem;
		height: 2.4rem;
		padding: 0.25rem;
		border: 0;
		background: transparent;
		color: var(--sl-color-gray-2);
		border-radius: 0.45rem;
		cursor: pointer;
	}

	.mobile-menu-toggle svg { display: block; width: 1.25rem; height: 1.25rem; }

	.mobile-menu-toggle:hover { color: var(--sl-color-white); background: color-mix(in srgb, var(--sl-color-white) 6%, transparent); }

	:global(:root[data-theme='light']) .site-header {
		background: var(--sl-color-bg);
		border-bottom-color: color-mix(in srgb, var(--sl-color-white) 10%, transparent);
	}

	:global(:root[data-theme='light']) .site-brand__logo--dark {
		display: none;
	}

	:global(:root[data-theme='light']) .site-brand__logo--light {
		display: block;
	}

	:global(:root[data-theme='light']) .site-tabs__item,
	:global(:root[data-theme='light']) .site-search :global(button[data-open-modal]),
	:global(:root[data-theme='light']) .site-icon-link,
	:global(:root[data-theme='light']) .site-theme :global(starlight-theme-select label) {
		color: var(--sl-color-gray-2);
	}

	:global(:root[data-theme='light']) .site-tabs__item:hover,
	:global(:root[data-theme='light']) .site-tabs__item--active,
	:global(:root[data-theme='light']) .site-search :global(button[data-open-modal]:hover),
	:global(:root[data-theme='light']) .site-icon-link:hover,
	:global(:root[data-theme='light']) .site-theme :global(starlight-theme-select label:hover) {
		color: var(--sl-color-gray-1);
	}

	:global(:root[data-theme='light']) .site-tabs__item:hover {
		border-bottom-color: color-mix(in srgb, var(--sl-color-white) 16%, transparent);
	}

	:global(:root[data-theme='light']) .site-tabs__item--active {
		border-bottom-color: var(--sl-color-accent);
	}

	:global(:root[data-theme='light']) .site-search :global(button[data-open-modal]) {
		background: color-mix(in srgb, var(--sl-color-white) 3%, transparent);
		border-color: color-mix(in srgb, var(--sl-color-white) 12%, transparent);
	}

	:global(:root[data-theme='light']) .site-search :global(button[data-open-modal]:hover) {
		background: color-mix(in srgb, var(--sl-color-white) 6%, transparent);
		border-color: color-mix(in srgb, var(--sl-color-white) 18%, transparent);
	}

	:global(:root[data-theme='light']) .site-theme :global(starlight-theme-select label) {
		background: color-mix(in srgb, var(--sl-color-white) 3%, transparent);
		border-color: color-mix(in srgb, var(--sl-color-white) 12%, transparent);
	}

	:global(:root[data-theme='light']) .site-icon-link:hover {
		background: color-mix(in srgb, var(--sl-color-white) 5%, transparent);
	}

	@media (max-width: 900px) {
		.site-header__inner {
			gap: 0.45rem;
			flex-wrap: wrap;
			align-items: flex-start;
		}

		/* Show the mobile toggle and collapse tabs by default */
		.mobile-menu-toggle {
			display: inline-flex;
			margin-left: auto;
		}

		.site-tabs {
			display: none;
		}

		.site-actions {
			display: none;
			width: 100%;
			justify-content: flex-start;
			gap: 0.45rem;
			padding: 0.35rem 0 0.15rem;
		}

		.site-mobile-pages {
			display: none;
			width: 100%;
			flex-basis: 100%;
			padding: 0.5rem 0 0;
			border-top: 1px solid color-mix(in srgb, var(--sl-color-white) 10%, transparent);
			background: var(--sl-color-bg-nav);
		}

		.site-mobile-pages__title {
			margin: 0 0 0.45rem;
			font-size: 0.66rem;
			font-weight: 700;
			letter-spacing: 0.12em;
			text-transform: uppercase;
			color: var(--sl-color-gray-3);
		}

		.site-mobile-group {
			border: 1px solid color-mix(in srgb, var(--sl-color-white) 8%, transparent);
			border-radius: 0.6rem;
			background: var(--sl-color-bg-sidebar);
			overflow: clip;
		}

		.site-mobile-group + .site-mobile-group {
			margin-top: 0.45rem;
		}

		.site-mobile-group__summary {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 0.75rem;
			padding: 0.62rem 0.72rem;
			list-style: none;
			cursor: pointer;
			color: var(--sl-color-gray-1);
			font-size: 0.82rem;
			font-weight: 700;
			background: transparent;
		}

		.site-mobile-group__summary::-webkit-details-marker {
			display: none;
		}

		.site-mobile-group__summary svg {
			flex: none;
			transition: transform 140ms ease;
		}

		.site-mobile-group[open] .site-mobile-group__summary svg {
			transform: rotate(180deg);
		}

		.site-mobile-group__items {
			list-style: none;
			margin: 0;
			padding: 0 0.35rem 0.35rem;
			display: grid;
			gap: 0.15rem;
		}

		.site-mobile-group__link {
			display: block;
			padding: 0.44rem 0.65rem;
			border-radius: 0.4rem;
			color: var(--sl-color-gray-2);
			text-decoration: none;
			font-size: 0.9rem;
			line-height: 1.35;
		}

		.site-mobile-group__link:hover {
			color: var(--sl-color-white);
			background: color-mix(in srgb, var(--sl-color-white) 5%, transparent);
		}

		.site-mobile-group__link--current,
		.site-mobile-group__link[aria-current='page'] {
			color: var(--sl-color-white);
			background: color-mix(in srgb, var(--sl-color-accent) 22%, transparent);
		}

		/* When mobile menu is opened, reveal the tabs and actions rows */
		.site-header[data-mobile-open="true"] .site-tabs {
			display: flex;
			order: 3;
			flex-basis: 100%;
			padding-top: 0.1rem;
		}

		.site-header[data-mobile-open="true"] .site-actions {
			display: inline-flex;
			order: 4;
		}

		.site-header[data-mobile-open="true"] .site-mobile-pages {
			display: block;
			order: 5;
		}

		.site-brand__logo {
			height: 2.05rem;
		}
	}
</style>

<script is:inline>
	const sectionMatchers = [
		{ id: 'getting-started', matches: ['/getting-started/', '/'] },
		{ id: 'concepts', matches: ['/concepts/', '/architecture/', '/security/', '/advanced/'] },
		{ id: 'integrations', matches: ['/integrations/'] },
		{ id: 'policies', matches: ['/policies/', '/identity/', '/hitl/', '/deployment/'] },
		{ id: 'reference', matches: ['/reference/'] },
	];

	function normalizePathname(pathname) {
		if (!pathname || pathname === '/') return '/';
		return pathname.endsWith('/') ? pathname : `${pathname}/`;
	}

	function getSectionIdForPath(pathname) {
		const normalized = normalizePathname(pathname);
		const pathMatchers = sectionMatchers
			.flatMap(section =>
				section.matches
					.filter(m => m !== '/')
					.map(match => ({ section: section.id, match }))
			)
			.sort((a, b) => b.match.length - a.match.length);

		const matched = pathMatchers.find(({ match }) => normalized.startsWith(match));
		return matched ? matched.section : 'getting-started';
	}

	function updateActiveTab() {
		const sectionId = getSectionIdForPath(window.location.pathname);
		const tabs = document.querySelectorAll('.site-tabs__item');

		tabs.forEach(tab => {
			const isActive = tab.href.includes(`/${sectionId}/`);
			tab.classList.toggle('site-tabs__item--active', isActive);
			tab.setAttribute('aria-current', isActive ? 'page' : 'false');
		});
	}

	document.addEventListener('astro:page-load', updateActiveTab);
	updateActiveTab();

	// Keep the CSS nav height in sync with the actual header size so
	// `.main-frame` padding matches the header and avoids overlap on mobile.
	function updateNavHeight() {
		const header = document.querySelector('.site-header');
		if (!header) return;
		const h = Math.ceil(header.getBoundingClientRect().height);
		document.documentElement.style.setProperty('--sl-nav-height', `${h}px`);
	}

	// Mobile menu toggle behavior: toggle a `data-mobile-open` attribute
	// on the header so CSS can reveal the collapsed nav.
	function setupMobileToggle() {
		const header = document.querySelector('.site-header');
		const toggle = document.querySelector('.mobile-menu-toggle');
		if (!header || !toggle) return;

		toggle.addEventListener('click', () => {
			const open = header.getAttribute('data-mobile-open') === 'true';
			header.setAttribute('data-mobile-open', (!open).toString());
			toggle.setAttribute('aria-expanded', (!open).toString());
			// Update header height since nav becomes visible/hidden
			requestAnimationFrame(updateNavHeight);
		});
	}

	window.addEventListener('load', () => {
		setupMobileToggle();
		updateNavHeight();
	});

	window.addEventListener('resize', () => {
		// throttling not necessary for small site; keep simple
		updateNavHeight();
	});
</script>
