---
import { getSectionForPath } from '../lib/docs-nav.js';
import claudeLogo from '../assets/claude.svg?raw';
import chatgptLogo from '../assets/chatgpt.svg?raw';
import cursorLogo from '../assets/cursor.svg?raw';

const { entry } = Astro.locals.starlightRoute;
const section = getSectionForPath(Astro.url.pathname);
const title = entry.data.title;
const description = entry.data.description;
const markdown = entry.body ?? '';
const isHomepage = Astro.url.pathname === '/';
---

<div class="content-panel page-title-panel">
	<div class="sl-container page-title-panel__inner">
		<div class:list={{ 'page-title-panel__row': true, 'page-title-panel__row--compact': isHomepage }}>
			<span class="page-title-panel__section">{section.label.toUpperCase()}</span>
			<div class="page-title-panel__copy split-copy" data-split-copy>
				<button type="button" class="split-copy__main" data-copy-markdown aria-label="Copy Markdown">
					<span class="menu-icon">
						<svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
							<path d="M16 1H6a2 2 0 0 0-2 2v12h2V3h10V1Zm3 4H10a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2Zm0 16h-9V7h9v14Z" />
						</svg>
					</span>
					<span class="menu-text" data-copy-label>Copy Markdown</span>
				</button>
				<button type="button" class="split-copy__toggle" aria-haspopup="true" aria-expanded="false" data-toggle aria-label="More copy options">
					<svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor" aria-hidden="true"><path d="M7 10l5 5 5-5z"/></svg>
				</button>
				<div class="split-copy__menu" role="menu" data-menu hidden>
					<!-- Top group: Open in apps -->
					<div class="menu-group">
						<button role="menuitem" data-action="open-claude" class="menu-item">
							<span class="menu-item-left">
								<span class="menu-icon-inline" aria-hidden="true" set:html={claudeLogo}></span>
							</span>
							<span class="menu-item-text"><span class="muted">Open in </span><strong>Claude</strong></span>
							<span class="menu-item-right">
								<!-- external link icon -->
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M14 3h7v7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 14L21 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
							</span>
						</button>
						<button role="menuitem" data-action="open-chatgpt" class="menu-item">
							<span class="menu-item-left">
								<span class="menu-icon-inline" aria-hidden="true" set:html={chatgptLogo}></span>
							</span>
							<span class="menu-item-text"><span class="muted">Open in </span><strong>ChatGPT</strong></span>
							<span class="menu-item-right">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M14 3h7v7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 14L21 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
							</span>
						</button>
						<button role="menuitem" data-action="open-cursor" class="menu-item">
							<span class="menu-item-left">
								<span class="menu-icon-inline" aria-hidden="true" set:html={cursorLogo}></span>
							</span>
							<span class="menu-item-text"><span class="muted">Open in </span><strong>Cursor</strong></span>
							<span class="menu-item-right">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M14 3h7v7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 14L21 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
							</span>
						</button>
					</div>
					<hr class="menu-divider">
					<!-- Bottom group: local actions -->
					<div class="menu-group">
						<button role="menuitem" data-action="copy-markdown" class="menu-item local-item">
							<span class="menu-item-left">
								<svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><path d="M16 1H6a2 2 0 0 0-2 2v12h2V3h10V1Zm3 4H10a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2Zm0 16h-9V7h9v14Z" fill="currentColor"/></svg>
							</span>
							<span class="menu-item-text"><strong>Copy Markdown</strong></span>
						</button>
						<a role="menuitem" data-action="view-markdown" class="menu-link menu-item local-item" target="_blank" rel="noopener">
							<span class="menu-item-left">
								<svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" fill="#0EA5A4"/><text x="7" y="15" font-size="9" fill="#fff" font-family="Arial, sans-serif">MD</text></svg>
							</span>
							<span class="menu-item-text"><strong>View as Markdown</strong></span>
							<span class="menu-item-right">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M14 3h7v7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 14L21 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
							</span>
						</a>
					</div>
				</div>
			</div>
		</div>
		{!isHomepage && (
			<div class="page-title-panel__body">
				<h1 id="_top" class="page-title-panel__title">{title}</h1>
				{description && <p class="page-title-panel__description">{description}</p>}
			</div>
		)}
	</div>
</div>

<script define:vars={{ markdown }} data-astro-rerun is:inline>
(() => {
	const container = document.querySelector('[data-split-copy]');
	if (!container) return;
	const mainBtn = container.querySelector('[data-copy-markdown]');
	const toggle = container.querySelector('[data-toggle]');
	const menu = container.querySelector('[data-menu]');
	const viewLink = container.querySelector('[data-action="view-markdown"]');

	const originalLabel = mainBtn?.querySelector('[data-copy-label]')?.textContent ?? 'Copy Markdown';

	function computeGithubUrl() {
		const path = window.location.pathname || '/';
		if (path === '/' || path === '') return 'https://github.com/faramesh/faramesh-docs/blob/main/src/content/docs/index.mdx';
		const p = path.replace(/^\//, '').replace(/\/$/, '');
		return `https://github.com/faramesh/faramesh-docs/blob/main/src/content/docs/${p}.mdx`;
	}

	function showTemporaryMessage(el, text) {
		const prev = el.textContent;
		el.textContent = text;
		el.setAttribute('data-state', 'copied');
		setTimeout(() => { el.removeAttribute('data-state'); el.textContent = prev; }, 1400);
	}

	function openMenu() {
		toggle.setAttribute('aria-expanded', 'true');
		menu.removeAttribute('hidden');
	}

	function closeMenu({ restoreFocus = false } = {}) {
		toggle.setAttribute('aria-expanded', 'false');
		menu.setAttribute('hidden', '');
		if (restoreFocus) toggle.focus();
	}

	async function copyToClipboard() {
		try {
			await navigator.clipboard.writeText(markdown || '');
			showTemporaryMessage(mainBtn.querySelector('[data-copy-label]'), 'Copied!');
			return true;
		} catch (e) {
			showTemporaryMessage(mainBtn.querySelector('[data-copy-label]'), 'Copy failed');
			return false;
		}
	}

	mainBtn.addEventListener('click', async () => {
		await copyToClipboard();
	});

	toggle.addEventListener('click', (e) => {
		const expanded = toggle.getAttribute('aria-expanded') === 'true';
		if (expanded) {
			closeMenu();
		} else {
			openMenu();
		}
	});

	if (!window.__farameshCopyMenuDocListeners) {
		window.__farameshCopyMenuDocListeners = true;
		document.addEventListener('click', (e) => {
			const active = document.querySelector('[data-split-copy]');
			if (!active || active.contains(e.target)) return;
			const activeToggle = active.querySelector('[data-toggle]');
			const activeMenu = active.querySelector('[data-menu]');
			if (activeToggle?.getAttribute('aria-expanded') === 'true') {
				activeToggle.setAttribute('aria-expanded', 'false');
				activeMenu?.setAttribute('hidden', '');
			}
		});
		document.addEventListener('keydown', (e) => {
			if (e.key !== 'Escape') return;
			const active = document.querySelector('[data-split-copy]');
			const activeToggle = active?.querySelector('[data-toggle]');
			if (activeToggle?.getAttribute('aria-expanded') === 'true') {
				activeToggle.setAttribute('aria-expanded', 'false');
				active.querySelector('[data-menu]')?.setAttribute('hidden', '');
				activeToggle.focus();
			}
		});
	}

	menu.addEventListener('click', async (e) => {
		const btn = e.target.closest('[role="menuitem"]') || e.target.closest('[data-action]');
		if (!btn) return;
		const action = btn.dataset.action;

		if (action === 'open-claude') {
			const url = `https://claude.ai/new?q=${encodeURIComponent(markdown || '')}`;
			window.open(url, '_blank');
		} else if (action === 'open-chatgpt') {
			// Open ChatGPT with query param (best-effort)
			const url = `https://chatgpt.com/?q=${encodeURIComponent(markdown || '')}`;
			window.open(url, '_blank');
		} else if (action === 'open-cursor') {
			await copyToClipboard();
			showTemporaryMessage(mainBtn.querySelector('[data-copy-label]'), 'Copied for Cursor');
		} else if (action === 'copy-markdown') {
			await copyToClipboard();
		}
		// Close menu after action
		closeMenu({ restoreFocus: true });
	});

	// Set view link href
	if (viewLink) {
		viewLink.href = computeGithubUrl();
	}
})();
</script>

<style>
	.page-title-panel {
		background: transparent;
	}

	.page-title-panel__inner {
		padding-top: 1.25rem;
		padding-bottom: 0.75rem;
	}

	.page-title-panel__row {
		display: flex;
		align-items: center;
		border-radius: 0.45rem;
		gap: 1rem;
		margin-bottom: 0.85rem;
	}

	.page-title-panel__row--compact {
		margin-bottom: 0;
	}

	.page-title-panel__section {
		color: var(--sl-color-gray-3);
		font-size: 0.82rem;
		font-weight: 600;
		line-height: 1;
	}

	.page-title-panel__copy {
		position: relative;
		display: inline-flex;
		align-items: stretch;
		margin-left: auto;
		overflow: visible;
	}

	.page-title-panel__copy[data-state='copied'] {
		color: var(--sl-color-white);
	}

	.page-title-panel__body {
		margin: 0.75rem 0 0;
		max-width: 65ch;
	}

	.page-title-panel__copy:hover {
		color: var(--sl-color-white);
	}

	.page-title-panel__copy:focus-within {
		outline: none;
	}

	.split-copy {
		position: relative;
		display: inline-flex;
		align-items: stretch;
		border: 1px solid color-mix(in srgb, var(--sl-color-white) 10%, transparent);
		border-radius: 0.65rem;
		background: color-mix(in srgb, var(--sl-color-white) 4%, transparent);
		overflow: visible;
	}

	.split-copy__main,
	.split-copy__toggle {
		height: 2rem;
		border: 0;
		background: transparent;
		color: var(--sl-color-gray-2);
		font-size: 0.83rem;
		font-weight: 600;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		padding: 0;
	}

	.split-copy__main {
		gap: 0.5rem;
		padding: 0 0.85rem;
		border-radius: 0.65rem 0 0 0.65rem;
		min-width: 0;
		flex: 1 1 auto;
		justify-content: flex-start;
	}

	.split-copy__toggle {
		width: 2rem;
		border-left: 1px solid color-mix(in srgb, var(--sl-color-white) 10%, transparent);
		border-radius: 0 0.65rem 0.65rem 0;
		flex: 0 0 2rem;
	}

	.split-copy:hover {
		background: color-mix(in srgb, var(--sl-color-white) 6%, transparent);
	}

	.split-copy:focus-within {
		border-color: color-mix(in srgb, var(--sl-color-white) 16%, transparent);
	}

	.split-copy__menu[hidden] {
		display: none !important;
	}

	.split-copy__menu {
		position: absolute;
		top: 100%;
		right: 0;
		z-index: 1000;
		margin-top: 0.45rem;
		min-width: 14rem;
		width: max-content;
		max-width: min(15rem, calc(100vw - 1.5rem));
		padding: 0.35rem;
		border: 1px solid color-mix(in srgb, var(--sl-color-white) 10%, transparent);
		border-radius: 0.8rem;
		background: var(--sl-color-bg);
		box-shadow: 0 18px 36px rgba(0, 0, 0, 0.18);
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.split-copy__menu .menu-group {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.split-copy__menu .menu-divider {
		border: 0;
		height: 1px;
		margin: 0.25rem 0;
		background: color-mix(in srgb, var(--sl-color-white) 10%, transparent);
	}

	.split-copy__menu .menu-item,
	.split-copy__menu .menu-link {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		width: 100%;
		padding: 0.58rem 0.7rem;
		border: 0;
		border-radius: 0.55rem;
		background: transparent;
		color: var(--sl-color-gray-2);
		text-align: left;
		text-decoration: none;
		cursor: pointer;
		font-size: 0.92rem;
		line-height: 1.2;
	}

	.split-copy__menu .menu-item:hover,
	.split-copy__menu .menu-link:hover {
		background: color-mix(in srgb, var(--sl-color-white) 6%, transparent);
	}

	.split-copy__menu .menu-item-left,
	.split-copy__menu .menu-item-right {
		flex: 0 0 auto;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.split-copy__menu .menu-item-left {
		width: 1rem;
	}

	.split-copy__menu .menu-item-right {
		margin-left: auto;
		opacity: 0.9;
	}

	.split-copy__menu .menu-item-text {
		flex: 1 1 auto;
		min-width: 0;
		display: inline-flex;
		align-items: center;
		gap: 0.2rem;
		white-space: nowrap;
	}

	.split-copy__menu .muted {
		color: var(--sl-color-gray-3);
		font-weight: 400;
	}

	.split-copy__menu strong,
	.split-copy__menu .local-item strong {
		font-weight: 700;
		color: var(--sl-color-white);
	}

	.split-copy__menu .menu-icon-inline {
		display: inline-flex;
		width: 16px;
		height: 16px;
		color: currentColor;
	}

	.split-copy__menu .menu-icon-inline svg {
		display: block;
		width: 16px;
		height: 16px;
	}

	:global(:root[data-theme='light']) .page-title-panel__section {
		color: #64748b;
	}

	:global(:root[data-theme='light']) .page-title-panel__copy {
		background: #f8fafc;
		border-color: #dbe2ea;
		color: #475569;
	}

	:global(:root[data-theme='light']) .page-title-panel__copy:hover {
		background: #eef2f7;
		border-color: #cbd5e1;
		color: #0f172a;
	}

	:global(:root[data-theme='light']) .page-title-panel__copy[data-state='copied'] {
		background: #dbeafe;
		border-color: #93c5fd;
		color: #0f172a;
	}

	:global(:root[data-theme='light']) .split-copy {
		background: #f8fafc;
		border-color: #dbe2ea;
		color: #475569;
	}

	:global(:root[data-theme='light']) .split-copy:hover {
		background: #eef2f7;
		border-color: #cbd5e1;
	}

	:global(:root[data-theme='light']) .split-copy__menu {
		background: #ffffff;
		border-color: #e6eef6;
		box-shadow: 0 18px 36px rgba(15, 23, 42, 0.12);
		color: #0f172a;
	}

	:global(:root[data-theme='light']) .split-copy__menu .menu-item:hover,
	:global(:root[data-theme='light']) .split-copy__menu .menu-link:hover {
		background: rgba(15, 23, 42, 0.04);
	}

	:global(:root[data-theme='light']) .split-copy__menu .muted {
		color: #64748b;
	}

	:global(:root[data-theme='light']) .split-copy__menu strong,
	:global(:root[data-theme='light']) .split-copy__menu .local-item strong {
		color: #0f172a;
	}

	:global(:root[data-theme='light']) .split-copy__menu .menu-divider {
		background: #e2e8f0;
	}

	@media (max-width: 900px) {
		.page-title-panel__row {
			flex-wrap: wrap;
		}

		.page-title-panel__copy {
			margin-left: auto;
		}
	}
</style>