---
const { eyebrow, title, body, primaryHref, primaryLabel, secondaryHref, secondaryLabel } = Astro.props;
---

<section class="home-hero">
	{eyebrow && <span class="home-hero__eyebrow">[{eyebrow}]</span>}
	<h1 class="home-hero__title">{title}</h1>
	{body && <p class="home-hero__body">{body}</p>}
	{(primaryHref || secondaryHref) && (
		<div class="home-hero__actions">
			{primaryHref && (
				<a class="home-hero__btn home-hero__btn--primary" href={primaryHref}>
					{primaryLabel ?? 'Get started'}
				</a>
			)}
			{secondaryHref && (
				<a class="home-hero__btn" href={secondaryHref}>
					{secondaryLabel ?? 'Learn more'}
				</a>
			)}
		</div>
	)}
</section>
