---
const { eyebrow, title, body, primaryHref, primaryLabel, secondaryHref, secondaryLabel } = Astro.props;
---

<section class="home-hero">
	{eyebrow && <span class="home-hero__eyebrow">[{eyebrow}]</span>}
	<h1 class="home-hero__title">{title}</h1>
	{body && <p class="home-hero__body">{body}</p>}
	{(primaryHref || secondaryHref) && (
		<div class="home-hero__actions">
			{primaryHref && (
				<a class="home-hero__btn home-hero__btn--primary" href={primaryHref}>
					{primaryLabel ?? 'Get started'}
				</a>
			)}
			{secondaryHref && (
				<a class="home-hero__btn" href={secondaryHref}>
					{secondaryLabel ?? 'Learn more'}
				</a>
			)}
		</div>
	)}
</section>

<style>
	.home-hero {
		display: grid;
		gap: 0.7rem;
		padding: 1.6rem 0 1.8rem;
		border-bottom: 1px solid color-mix(in srgb, var(--sl-color-white) 8%, transparent);
		margin: 0 0 1rem;
	}

	.home-hero__eyebrow {
		display: inline-block;
		width: fit-content;
		padding: 0.18rem 0.55rem 0.2rem;
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		color: var(--sl-color-accent-high);
		background: color-mix(in srgb, var(--sl-color-accent) 14%, transparent);
		border: 1px solid color-mix(in srgb, var(--sl-color-accent) 30%, transparent);
		border-radius: 0.25rem;
		text-transform: uppercase;
	}

	.home-hero__title {
		margin: 0;
		font-size: clamp(1.75rem, 2.6vw, 2.4rem);
		line-height: 1.15;
		letter-spacing: -0.015em;
		color: var(--sl-color-white);
		font-weight: 700;
		max-width: 32ch;
	}

	.home-hero__body {
		margin: 0;
		font-size: 1rem;
		color: var(--sl-color-gray-2);
		line-height: 1.6;
		max-width: 64ch;
	}

	.home-hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		margin-top: 0.4rem;
	}

	.home-hero__btn {
		display: inline-flex;
		align-items: center;
		padding: 0.45rem 0.9rem;
		border-radius: 0.35rem;
		border: 1px solid color-mix(in srgb, var(--sl-color-white) 14%, transparent);
		background: transparent;
		color: var(--sl-color-white);
		font-size: 0.9rem;
		font-weight: 600;
		text-decoration: none;
		transition: border-color 130ms ease, background-color 130ms ease;
	}

	.home-hero__btn:hover {
		border-color: color-mix(in srgb, var(--sl-color-accent) 60%, transparent);
		background: color-mix(in srgb, var(--sl-color-accent) 8%, transparent);
	}

	.home-hero__btn--primary {
		background: var(--sl-color-accent);
		border-color: var(--sl-color-accent);
		color: var(--sl-color-black);
	}

	.home-hero__btn--primary:hover {
		background: var(--sl-color-accent-high);
		border-color: var(--sl-color-accent-high);
	}

	:global(:root[data-theme='light']) .home-hero {
		border-bottom-color: #e2e8f0;
	}

	:global(:root[data-theme='light']) .home-hero__eyebrow {
		color: #1d4ed8;
		background: #eff6ff;
		border-color: #bfdbfe;
	}

	:global(:root[data-theme='light']) .home-hero__title {
		color: #0f172a;
	}

	:global(:root[data-theme='light']) .home-hero__body {
		color: #475569;
	}

	:global(:root[data-theme='light']) .home-hero__btn {
		color: #0f172a;
		border-color: #cbd5e1;
	}

	:global(:root[data-theme='light']) .home-hero__btn:hover {
		border-color: var(--sl-color-accent);
		background: #eff6ff;
	}

	:global(:root[data-theme='light']) .home-hero__btn--primary {
		background: #0f172a;
		border-color: #0f172a;
		color: #ffffff;
	}

	:global(:root[data-theme='light']) .home-hero__btn--primary:hover {
		background: #1e293b;
		border-color: #1e293b;
	}
</style>
